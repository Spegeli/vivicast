# Copy this file to `keystore.properties` (gitignored) and fill in your real values to produce a signed
# `assembleRelease`. NEVER commit the real `keystore.properties` or the `.jks` — the repo is public.
# CI (GitHub Actions) supplies these via environment variables instead:
#   VIVICAST_KEYSTORE_FILE / VIVICAST_STORE_PASSWORD / VIVICAST_KEY_ALIAS / VIVICAST_KEY_PASSWORD
storeFile=vivicast-release.jks
storePassword=your-keystore-password
keyAlias=vivicast
keyPassword=your-key-password
