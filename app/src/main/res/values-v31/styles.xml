<resources>
    <!-- API 31+: native SplashScreen-Icon (Vivicast-Marke) auf Navy-Grund. -->
    <style name="Theme.Vivicast" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:colorAccent">#E5B84B</item>
        <item name="android:windowBackground">@android:color/black</item>
        <item name="android:windowSplashScreenBackground">#050914</item>
        <item name="android:windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
    </style>
</resources>
