<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Interner Datei-Picker (SAF ist auf Android TV unzuverlässig). Gestaffelt nach API:
         ≤29 Runtime-READ + WRITE für File-Zugriff; 30+ MANAGE_EXTERNAL_STORAGE ("Alle Dateien").
         requestLegacyExternalStorage (unten am <application>) opt-tet API 29 (Android 10) zurück auf
         Legacy-Storage, damit der File-API-Zugriff von StorageAccess dort greift. NICHT entfernen: das
         Geräte-API-Level (nicht targetSdk) entscheidet die Wirkung — auf 30+ ignoriert, ≤28 irrelevant. -->
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="29" />
    <uses-permission
        android:name="android.permission.MANAGE_EXTERNAL_STORAGE"
        tools:ignore="ScopedStorage" />

    <!-- Package visibility (Android 11+): make the "All files access" settings screens resolvable so
         the picker can detect whether a grant screen exists (else it can't distinguish "no screen" from
         "screen hidden by visibility" and would wrongly fall back to the App-folder-only view). -->
    <queries>
        <intent>
            <action android:name="android.settings.MANAGE_APP_ALL_FILES_ACCESS_PERMISSION" />
        </intent>
        <intent>
            <action android:name="android.settings.MANAGE_ALL_FILES_ACCESS_PERMISSION" />
        </intent>
    </queries>

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".VivicastApplication"
        android:allowBackup="false"
        android:requestLegacyExternalStorage="true"
        android:banner="@drawable/banner"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vivicast">
        <activity
            android:name=".MainActivity"
            android:banner="@drawable/banner"
            android:exported="true">
            <meta-data
                android:name="android.app.searchable"
                android:resource="@xml/searchable" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="channel"
                    android:scheme="vivicast" />
                <data
                    android:host="movie"
                    android:scheme="vivicast" />
                <data
                    android:host="series"
                    android:scheme="vivicast" />
                <data
                    android:host="episode"
                    android:scheme="vivicast" />
            </intent-filter>
        </activity>
        <!-- Exported only so the system Android-TV global-search process (which holds GLOBAL_SEARCH) can
             query suggestions; the permission keeps arbitrary third-party apps from enumerating the catalog. -->
        <provider
            android:name=".search.AndroidTvSearchSuggestionProvider"
            android:authorities="com.vivicast.tv.search"
            android:exported="true"
            android:permission="android.permission.GLOBAL_SEARCH"
            android:readPermission="android.permission.GLOBAL_SEARCH" />
        <receiver
            android:name=".BootLaunchReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Manche (ältere/günstige) TV-Boxen feuern QUICKBOOT statt BOOT_COMPLETED. -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
