<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Package visibility (Android 11+): nötig, damit queryIntentActivities einen echten
         SAF-Dateipicker einer Drittapp findet (sonst nur der TV-Framework-Stub sichtbar). -->
    <queries>
        <intent>
            <action android:name="android.intent.action.OPEN_DOCUMENT" />
            <data android:mimeType="*/*" />
        </intent>
    </queries>

    <uses-feature
        android:name="android.software.leanback"
        android:required="true" />
    <uses-feature
        android:name="android.hardware.touchscreen"
        android:required="false" />

    <application
        android:name=".VivicastApplication"
        android:allowBackup="false"
        android:banner="@drawable/banner"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Vivicast">
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <meta-data
                android:name="android.app.searchable"
                android:resource="@xml/searchable" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data
                    android:host="channel"
                    android:scheme="vivicast" />
                <data
                    android:host="movie"
                    android:scheme="vivicast" />
                <data
                    android:host="series"
                    android:scheme="vivicast" />
                <data
                    android:host="episode"
                    android:scheme="vivicast" />
            </intent-filter>
        </activity>
        <provider
            android:name=".search.AndroidTvSearchSuggestionProvider"
            android:authorities="com.vivicast.tv.search"
            android:exported="true" />
        <receiver
            android:name=".BootLaunchReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- Manche (ältere/günstige) TV-Boxen feuern QUICKBOOT statt BOOT_COMPLETED. -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
                <action android:name="com.htc.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>
    </application>
</manifest>
